# Required by the scheduler API.
# Use sslmode=require for Supabase or other TLS-only Postgres providers.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require

# Optional helper-script shortcut used by tools/db_ping.py and
# tools/run_test_profile_scheduler.py. Do not use real secrets in this file.
DB_PASSWORD=replace_me

# Optional debug flag for candidate lookup. Accepted true values:
# 1, true, yes, on
CANDIDATE_BUILDER_DEBUG=0
