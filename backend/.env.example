# Server
PORT=3001
NODE_ENV=development

# Session — use a long random string in production (e.g. openssl rand -hex 32)
SESSION_SECRET=your-session-secret-here

# CORS — origin of your frontend dev server
# In development, any localhost port is allowed automatically.
# In production, set this to your deployed frontend URL.
CORS_ORIGIN=https://your-frontend-domain.com

# Database (individual params — used when DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=watchtower
DB_USER=watchtower
DB_PASSWORD=your-db-password

# Supabase connection string — overrides individual DB_* vars when set
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
