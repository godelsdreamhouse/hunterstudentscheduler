# Server
PORT=3001
NODE_ENV=development

# Session — use a long random string in production (e.g. openssl rand -hex 32)
SESSION_SECRET=your-session-secret-here

# CORS — origin of your frontend dev server
# In development, any localhost port is allowed automatically.
# In production, set this to your deployed frontend URL.
CORS_ORIGIN=https://watchtower-red.vercel.app

# Supabase/PostgreSQL connection string used for auth, sessions, and course search
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
