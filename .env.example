# Frontend API base URL.
# For local dev, the Vite proxy can handle backend API calls, but setting this
# explicitly is also supported.
VITE_API_URL=http://localhost:3001

# Parser service base URL.
# Leave empty in local dev to use the Vite /AuditParse proxy.
VITE_PARSER_URL=

# Scheduler service base URL.
# Leave empty in local dev to use the Vite /api/schedule proxy.
VITE_SCHEDULER_URL=
